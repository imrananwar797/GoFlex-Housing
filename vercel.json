{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/v1/core/:path*",
      "destination": "/api/core/index.ts"
    },
    {
      "source": "/api/v1/ai/:path*",
      "destination": "/api/ai/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/frontend/$1"
    }
  ],
  "functions": {
    "api/core/index.ts": {
      "runtime": "@vercel/node"
    },
    "api/ai/main.py": {
      "runtime": "@vercel/python"
    }
  }
}
