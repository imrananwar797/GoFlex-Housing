{
  "version": 2,
  "outputDirectory": "apps/frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/v1/core/:path*",
      "destination": "/api/core.ts"
    },
    {
      "source": "/api/v1/ai/:path*",
      "destination": "/api/ai.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/core.ts": {
      "memory": 1024,
      "maxDuration": 15
    },
    "api/ai.py": {
      "memory": 1024,
      "maxDuration": 20
    }
  }
}