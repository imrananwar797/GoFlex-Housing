{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/v1/core/:path*",
      "destination": "/api/core.ts"
    },
    {
      "source": "/api/v1/ai/:path*",
      "destination": "/api/ai.py"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/frontend/$1"
    }
  ],
  "functions": {
    "api/core.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/ai.py": {
      "memory": 1024,
      "maxDuration": 15
    }
  }
}