{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/v1/core/:path*",
      "destination": "/api/core"
    },
    {
      "source": "/api/v1/ai/:path*",
      "destination": "/api/ai/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/core.ts": {
      "maxDuration": 15
    },
    "api/ai.py": {
      "maxDuration": 20
    }
  }
}