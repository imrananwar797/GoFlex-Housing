{
  "name": "goflex-housing-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "backend/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:core": "npm run dev --workspace=backend/core",
    "dev:ai": "npm run dev --workspace=backend/ai",
    "build": "prisma generate --schema=backend/core/prisma/schema.prisma && turbo run build --filter=frontend",
    "vercel-build": "prisma generate --schema=backend/core/prisma/schema.prisma && turbo run build --filter=frontend",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.9.9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3"
  }
}
