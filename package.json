{
  "name": "goflex-housing-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "api/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:core": "npm run dev --workspace=api/core",
    "dev:ai": "npm run dev --workspace=api-ai",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3"
  }
}
